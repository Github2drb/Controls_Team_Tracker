ext\"></td>\n          <td><input type=\"text\"></td>\n        </tr>\n        <tr>\n          <td>Safety Incidents</td>\n          <td style=\"padding:4px\">\n            <label class=\"cpf-checkbox-item\" style=\"margin:0\"><input type=\"checkbox\"> Low</label>\n            <label class=\"cpf-checkbox-item\" style=\"margin:0\"><input type=\"checkbox\"> Medium</label>\n            <label class=\"cpf-checkbox-item\" style=\"margin:0\"><input type=\"checkbox\"> High</label>\n          </td>\n          <td style=\"padding:4px\">\n            <label class=\"cpf-checkbox-item\" style=\"margin:0\"><input type=\"checkbox\"> Low</label>\n            <label class=\"cpf-checkbox-item\" style=\"margin:0\"><input type=\"checkbox\"> Medium</label>\n            <label class=\"cpf-checkbox-item\" style=\"margin:0\"><input type=\"checkbox\"> High</label>\n          </td>\n          <td><input type=\"text\"></td>\n          <td><input type=\"text\"></td>\n        </tr>\n      </table>\n    </div>\n\n    <!-- QUALITY ASSURANCE -->\n    <div class=\"cpf-section\">\n      <h3>9. Quality Assurance Checklist</h3>\n      <strong>Design Review</strong>\n      <div class=\"cpf-checkbox-group\">\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> System architecture reviewed</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Safety systems validated</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Client requirements verified</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Code standards checked</label>\n      </div>\n      <strong style=\"display:block;margin-top:10px\">Testing & Validation</strong>\n      <div class=\"cpf-checkbox-group\">\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Unit testing completed</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Integration testing passed</label>\n        <label class=\"cpf-checkbox-item\"><i