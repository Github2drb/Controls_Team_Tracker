 <div class=\"cpf-checkbox-group\">\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> All systems tested & operational</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Client training completed</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Documentation handed over</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Warranty terms explained</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Support procedures established</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Project retrospective conducted</label>\n        <label class=\"cpf-checkbox-item\"><input type=\"checkbox\"> Lessons learned documented</label>\n      </div>\n      <strong style=\"display:block;margin-top:10px\">Team Performance Review</strong>\n      <table class=\"cpf-table\" style=\"margin-top:10px\">\n        <tr><th>Team Member</th><th>Rating</th><th>Key Contributions</th><th>Areas for Development</th></tr>\n        <tr><td><input type=\"text\"></td><td><select><option>Excellent</option><option>Good</option><option>Satisfactory</option></select></td><td><input type=\"text\"></td><td><input type=\"text\"></td></tr>\n      </table>\n    </div>\n\n    <!-- FOOTER -->\n    <div class=\"cpf-section\">\n      <h3>13. Document Information</h3>\n      <div class=\"cpf-grid\">\n        <div class=\"cpf-group\">\n          <label>Template Version</label>\n          <input type=\"text\" value=\"1.0\">\n        </div>\n        <div class=\"cpf-group\">\n          <label>Last Updated</label>\n          <input type=\"date\">\n        </div>\n        <div class=\"cpf-group\">\n          <label>Prepared By</label>\n          <input type=\"text\">\n        </div>\n        <div class=\"cpf-group\">\n          <label>Approved By</label>\n          <input type=\"text\">\n        </div>\n      </div>\n    </div>\n\n    <!-- ACTION BUTTONS -->\n    <div class=\"cpf-buttons\">\n      <button type=\"button\" class=\"cpf-btn cpf-btn-save\" onclick=\"saveFormLocal()\">💾 Save Locally</button>\n      <button type=\"button\" class=\"cpf-btn cpf-btn-pdf\" onclick=\"downloadPDF()\">📥 Download PDF</button>\n      <button type=\"reset\" class=\"cpf-btn cpf-btn-reset\">🔄 Reset Form</button>\n    </div>\n\n    <div id=\"cpf-status\" class=\"cpf-status\"></div>\n  </form>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js\"></script>\n<script>\nconst form = document.getElementById('cpf-form');\n\n// Save to localStorage\nfunction saveFormLocal() {\n  try {\n    const formData = new FormData(form);\n    const data = Object.fromEntries(formData);\n    const projectCode = form.querySelector('input[type=\"text\"]').value || 'Project';\n    localStorage.setItem('cpf-' + projectCode + '-' + Date.now(), JSON.stringify(data));\n    showStatus('✅ Form saved successfully!', 'success');\n  } catch(e) {\n    showStatus('❌ Error saving form: ' + e.message, 'success');\n  }\n}\n\n// Download PDF\nfunction downloadPDF() {\n  try {\n    const projectCode = form.querySelectorAll('input[type=\"text\"]')[1]?.value || 'Controls_Project';\n    const element = document.querySelector('.cpf-container');\n    \n    const opt = {\n      margin: [10, 10, 10, 10],\n      filename: projectCode + '_' + new Date().toLocaleDateString().replace(/\\//g, '-') + '.pdf',\n      image: { type: 'jpeg', quality: 0.98 },\n      html2canvas: { scale: 2, useCORS: true },\n      jsPDF: { orientation: 'portrait', unit: 'mm', format: 'a4' }\n    };\n    \n    html2pdf().set(opt).from(element).save();\n    showStatus('✅ PDF downloading...', 'success');\n  } catch(e) {\n    showStatus('❌ Error downloading PDF: ' + e.message, 'success');\n  }\n}\n\nfunction showStatus(msg, type) {\n  const status = document.getElementById('cpf-status');\n  status.textContent = msg;\n  status.className = 'cpf-status ' + type + ' show';\n  setTimeout(() => status.className = 'cpf-status', 4000);\n}\n\n// Auto-save on change\nform.addEventListener('change', function() {\n  const projectCode = form.querySelectorAll('input[type=\"text\"]')[1]?.value || 'AutoSave';\n  const formData = new FormData(form);\n  localStorage.setItem('cpf-autosave-' + projectCode, JSON.stringify(Object.fromEntries(formData)));\n});\n\n// Load saved data on page load\nwindow.addEventListener('load', function() {\n  const projectCode = form.querySelectorAll('input[type=\"text\"]')[1]?.value || 'AutoSave';\n  const saved = localStorage.getItem('cpf-autosave-' + projectCode);\n  if (saved) {\n    try {\n      const data = JSON.parse(saved);\n      Object.keys(data).forEach(key => {\n        const field = form.querySelector(`[name=\"${key}\"]`);\n        if (field) field.value = data[key];\n      });\n      showStatus('📝 Form data restored from last save', 'success');\n    } catch(e) {\n      console.log('Could not restore data:', e);\n    }\n  }\n});\n</script>",
